# =====================================================
# REGRESSION METRICS
# MAE, MSE, RMSE, R2 Score
# =====================================================

from sklearn.metrics import (
    mean_absolute_error,
    mean_squared_error,
    r2_score
)

import numpy as np

# Actual Values
y_true = [100, 120, 130, 150, 170]

# Predicted Values
y_pred = [110, 115, 135, 145, 165]

# =====================================================
# MAE
# =====================================================

mae = mean_absolute_error(y_true, y_pred)

print("MAE:", mae)

# =====================================================
# MSE
# =====================================================

mse = mean_squared_error(y_true, y_pred)

print("MSE:", mse)

# =====================================================
# RMSE
# =====================================================

rmse = np.sqrt(mse)

print("RMSE:", rmse)

# =====================================================
# R2 SCORE
# =====================================================

r2 = r2_score(y_true, y_pred)

print("R2 Score:", r2)